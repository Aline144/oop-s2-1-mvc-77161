@model IEnumerable<CommunityLibraryDesk1.Models.Loan>

@{
    ViewData["Title"] = "Loans";
}

<h1>Loans</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Loan</a>
</p>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Book</th>
        <th>Member</th>
        <th>Loan Date</th>
        <th>Due Date</th>
        <th>Returned Date</th>
        <th>Status</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Book?.Title</td>
            <td>@item.Member?.FullName</td>
            <td>@item.LoanDate.ToShortDateString()</td>
            <td>@item.DueDate.ToShortDateString()</td>
            <td>@(item.ReturnedDate?.ToShortDateString() ?? "-")</td>
            <td>
                @if (item.ReturnedDate != null)
                {
                    <span class="badge bg-success">Returned</span>
                }
                else if (item.IsOverdue)
                {
                    <span class="badge bg-danger">Overdue</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Active</span>
                }
            </td>
            <td>
                @if (item.ReturnedDate == null)
                {
                    <form asp-action="MarkReturned" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="btn btn-sm btn-success">Mark Returned</button>
                    </form>
                }
            </td>
        </tr>
    }
    </tbody>
</table>