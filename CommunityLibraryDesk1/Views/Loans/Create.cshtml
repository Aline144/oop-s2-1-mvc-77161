@model CommunityLibraryDesk1.ViewModels.LoanCreateViewModel

@{
    ViewData["Title"] = "Create Loan";
}

<h1>Create Loan</h1>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="BookId" class="form-label"></label>
        <select asp-for="BookId" asp-items="Model.AvailableBooks" class="form-select">
            <option value="">Select a book</option>
        </select>
        <span asp-validation-for="BookId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MemberId" class="form-label"></label>
        <select asp-for="MemberId" asp-items="Model.Members" class="form-select">
            <option value="">Select a member</option>
        </select>
        <span asp-validation-for="MemberId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="LoanDate" class="form-label"></label>
        <input asp-for="LoanDate" class="form-control" />
        <span asp-validation-for="LoanDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DueDate" class="form-label"></label>
        <input asp-for="DueDate" class="form-control" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}